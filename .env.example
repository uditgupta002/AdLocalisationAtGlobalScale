# ── Python worker environment (OmniSwarm pipeline) ─────────────────────────
# Copy to .env. The worker shares the same Aurora DSQL cluster and S3 buckets
# as the Vercel frontend.

# Mock / live toggles
MOCK_SERVICES=True
S3_LIVE_MODE=False
GEMINI_LIVE_MODE=False

# Worker / webhook server
WEBHOOK_PORT=3001
WEBHOOK_AUTH_TOKEN=your-bearer-token
# Shared secret the Vercel app uses to trigger jobs (must match WORKER_AUTH_TOKEN there)
WORKER_AUTH_TOKEN=choose-a-long-shared-secret

# Target markets (comma-separated)
TARGET_MARKETS=japan,germany,india,english

# Logging
LOG_LEVEL=INFO
ENV_MODE=development

# === AWS credentials (S3 + Aurora DSQL) ===
APP_AWS_REGION=us-east-1
APP_AWS_ACCESS_KEY_ID=your_access_key_id
APP_AWS_SECRET_ACCESS_KEY=your_secret_access_key

# === Amazon S3 ===
S3_MASTER_BUCKET=omniswarm-master-assets
S3_OUTPUT_BUCKET=omniswarm-localized-output

# === Amazon Aurora DSQL ===
# Leave empty to use the local SQLite fallback for offline dev.
DSQL_ENDPOINT=

# === Google Gemini (audio dubbing) ===
GEMINI_API_KEY=your_gemini_api_key_here
