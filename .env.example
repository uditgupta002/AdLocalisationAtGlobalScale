# === MVP Mode (Mock Layer Toggle) ===
MOCK_SERVICES=True
TIGRIS_LIVE_MODE=False

# === Webhook Server ===
WEBHOOK_PORT=3001
WEBHOOK_AUTH_TOKEN=your-bearer-token

# === Dashboard ===
DASHBOARD_PORT=3002

# === Target Markets (comma-separated) ===
TARGET_MARKETS=japan,germany,india,english

# === Logging & Env ===
LOG_LEVEL=INFO
ENV_MODE=development

# === Tigris Object Storage ===
TIGRIS_ACCESS_KEY_ID=tid_mockaccesskey
TIGRIS_SECRET_ACCESS_KEY=tsec_mocksecretkey
TIGRIS_ENDPOINT=https://t3.storage.dev
TIGRIS_MASTER_BUCKET=mcdonalds-master-assets
TIGRIS_OUTPUT_BUCKET=mcdonalds-localized-output

# === Google Gemini (Audio Dubbing) ===
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_LIVE_MODE=False

# === RunwayML (Video Generation) ===
RUNWAYML_API_KEY=rw_mockrunway

# === Shotstack (Video Overlay) ===
SHOTSTACK_API_KEY=ss_mockshotstack
SHOTSTACK_ENV=v1
