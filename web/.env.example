# ── Next.js (Vercel) environment ──────────────────────────────────────────
# Copy to .env.local for local dev, and set the same vars in the Vercel project.
#
# NOTE: we use APP_AWS_* (not AWS_*) because Vercel functions run on AWS Lambda,
# whose reserved AWS_ACCESS_KEY_ID/AWS_SECRET_ACCESS_KEY belong to Vercel itself.

# AWS credentials for our Aurora DSQL + S3 resources
APP_AWS_REGION=us-east-1
APP_AWS_ACCESS_KEY_ID=your_access_key_id
APP_AWS_SECRET_ACCESS_KEY=your_secret_access_key

# Aurora DSQL cluster endpoint (e.g. abcdef......dsql.us-east-1.on.aws)
DSQL_ENDPOINT=

# Amazon S3 buckets
S3_MASTER_BUCKET=omniswarm-master-assets
S3_OUTPUT_BUCKET=omniswarm-localized-output

# Python worker (the FFmpeg/Demucs/Gemini pipeline) that processes jobs
WORKER_URL=https://your-worker-host.example.com
WORKER_AUTH_TOKEN=choose-a-long-shared-secret
